# Local demo server
# Copy to .env for local-only use. Never put real production secrets in this file.

HOST=127.0.0.1
PORT=3007
NNZ_JWT_SECRET=

# Optional LLM adapter. Leave blank to use deterministic fallback replies.
NNZ_LLM_API_KEY=
NNZ_LLM_BASE_URL=
NNZ_LLM_MODEL=

# Local snapshot persistence. Prefer NNZ_DB_PATH for local demo work.
NNZ_RUNTIME_PERSISTENCE_MODE=snapshot
NNZ_DB_PATH=

# Existing snapshot Postgres runtime. Managed by Render in production.
# Do not use DATABASE_URL or NNZ_POSTGRES_URL for migration validation.
DATABASE_URL=
NNZ_POSTGRES_URL=

# Soul Ops admin access.
# NNZ_OPS_TOKEN maps to admin for backward compatibility.
NNZ_OPS_TOKEN=
NNZ_OPS_VIEWER_TOKEN=
NNZ_OPS_OPERATOR_TOKEN=
NNZ_OPS_ADMIN_TOKEN=

# Release validation inputs.
# Snapshot path must point to a local SQLite file or StoreSnapshot JSON.
NNZ_MIGRATION_SNAPSHOT_PATH=

# Disposable databases only. These must not match DATABASE_URL or NNZ_POSTGRES_URL.
NNZ_POSTGRES_INTEGRATION_URL=
NNZ_POSTGRES_SCOPED_RUNTIME_URL=
