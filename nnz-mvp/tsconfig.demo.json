{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist-cjs",
    "declaration": false,
    "types": ["node"]
  },
  "include": ["src/demo-server.ts", "src/domain/**/*.ts", "src/runtime/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "node_modules", "dist", "dist-cjs"]
}
